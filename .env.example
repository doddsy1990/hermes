TZ=Europe/London

# Bind to the Ubuntu server LAN IP for direct access from devices on the LAN.
HERMES_GATEWAY_BIND=192.168.178.37
HERMES_DASHBOARD_BIND=192.168.178.37

# Resource limits.
HERMES_MEM_LIMIT=2g
HERMES_CPUS=1.0

# Persistent Hermes config, credentials, sessions, skills, memory, and logs.
HERMES_DATA_PATH=/home/dodds/hermes/data

# Enable the dashboard service inside the container.
HERMES_DASHBOARD=1

# Path to the media server repo on the Ubuntu Docker host.
MEDIA_REPO_PATH=/home/dodds/docker

# Add provider keys/config required by your Hermes setup here.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

HERMES_DASHBOARD_BASIC_AUTH_USERNAME=dodds
HERMES_DASHBOARD_BASIC_AUTH_PASSWORD=32DK7xCK5sJlF!
