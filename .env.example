TZ=Europe/London

# Bind to 127.0.0.1 by default. Use 192.168.178.37 if you want LAN access.
HERMES_GATEWAY_BIND=127.0.0.1
HERMES_DASHBOARD_BIND=127.0.0.1

# Resource limits.
HERMES_MEM_LIMIT=2g
HERMES_CPUS=1.0

# Persistent Hermes config, credentials, sessions, skills, memory, and logs.
# On the Ubuntu server this is intended to live outside the git repo.
HERMES_DATA_PATH=/home/dodds/docker/hermes

# Enable the dashboard service inside the container.
HERMES_DASHBOARD=1

# Path to the media server repo on the Ubuntu Docker host.
MEDIA_REPO_PATH=/home/dodds/dodds-server

# Add provider keys/config required by your Hermes setup here.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
